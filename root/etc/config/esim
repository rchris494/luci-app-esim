config modem 'modem'
	option at_device '/dev/ttyUSB0'
	option wan_interface 'wwan0'
	option apdu_interface '/dev/ttyUSB0'

config settings 'settings'
	option auto_enable '1'
	option auto_reconnect '1'
	option verify_certs '1'
	option test_certificates '0'
	option send_notifications '1'
	option remove_notifications '1'
	option disable_on_switch '1'
	option reconnect_delay '5'
	option log_level 'info'
